:: S: studentDebate 1c [storylet]
{=

(storylet: when
$place's location is "Apesai"
and $place's sublocation is "Apesai Lighthouse"
and ($funcCheckExists: $place's events, "studentDebate", "inactive") is "active"
and ($funcCheckExists: $char's player's quests, "studentDebate", "") is not "active"
)
(exclusivity: 1)
(urgency: 2)
(metadata: "title", "Commotion Near the Lighthouse", "cardDesc", "A crowd has gathered around the gate of the Apesai Lighthouse, gawking, shouting, holding up in the air pieces of paper.", "img", "Assets/Portraits/Event_Argue_1.png",)

$cssColumnParent[

$cssColumnChild[
	$cssBox[
    	($funcImage: (passage:)'s img)
         $cssBoxItem[''(print: (passage:)'s title )''<br>(print: (passage:)'s cardDesc)]
    ]
]

$cssColumnChild[

(They're slipping each other promisory notes, some loudly claiming that their side will win...)
<br>
---
<ol>

<li>(link: "Inquire a bystander: What's going on?")[(goto: "studentDebate 1d")]

<li>(link: "Shove past the rabble. You have business with the davehmars.")[(goto: "studentDebate 1e")]

</ol>

]<!--end child-->
]<!--end parent-->


:: studentDebate 1d

(metadata:
"title", "Commotion Near the Lighthouse",
"cardDesc", "",
)

$cssColumnParent[

