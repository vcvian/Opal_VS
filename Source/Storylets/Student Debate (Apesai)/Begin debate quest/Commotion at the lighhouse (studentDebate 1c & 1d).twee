         $cssBoxItem[''(print: (passage:)'s title )''<br>(print: (passage:)'s cardDesc)]
    ]
]

$cssColumnChild[

(It is explained to you that there is a debate going on...)

<br>
---
<ol>
<li>($funcQuestUpdateLink: "Debate? Among the apprentices? Why, you cannot miss this.", "studentDebate", "active", "Junior debates are either a pain to watch or a source of much-needed entertainment after long hours of study - a senior has told you this after you asked him to appraise your performance in one such event.", "You're older and wiser now.", [], "S: studentDebate 2",)

<li>(link: "Walk away. You'll return once everyone is tired of this farce.")[(goto: "Apesai Lighthouse")]
<ol>
]<!--end child-->
]<!--end parent-->



