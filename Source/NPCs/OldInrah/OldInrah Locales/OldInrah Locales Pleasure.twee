    (if: _lie is true)[($funcOpinionGainLoss: "OldInrah", -5, "Koh-Inrah didn't appreciate you lying to her, even as a joke.")]
    (if: _lie is false)[($funcOpinionGainLoss: "OldInrah", 1, "Much goodwill is earned through the exchange of money, and the old woman happily takes yours.")]
