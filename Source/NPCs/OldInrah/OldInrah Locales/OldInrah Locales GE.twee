(if: _alreadyKnow is true)[(set: _doneText to "It is the same directions you've memorized. Was this a wise way to spend your money?")]
(else:)[(set: _doneText to "Pay close attention, and get your money's worth.")]
<br>


---
(link-rerun: _doneText)[{
	(if: _alreadyKnow is true)[($funcTempGainLoss: "impressionApesai", 1)]
    (if: _alreadyKnow is false)[($funcTempGainLoss: "impressionApesai", 5)]
    ($funcOpinionGainLoss: "OldInrah", 1, "Much goodwill is earned through the exchange of money, and the old woman happily takes yours.")
    (set: $char's OldInrah's energy's 1st to it - 1)
