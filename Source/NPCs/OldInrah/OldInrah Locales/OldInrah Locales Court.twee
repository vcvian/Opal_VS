(set: _doneText to "")
(if: _alreadyKnow is true)[(set: _doneText to "You already know your way to the courthouse. Still, a reminder is always good, so you tell yourself.")]
(else:)[(set: _doneText to "Take careful note of her instructions.")]
<br>


