    ($funcGainLoss: "item.", "mapInrah", 1)\
	($funcOpinionGainLoss: "OldInrah", 10, "The old woman seems elated. Is it because she has taken yet more rial from your hands? Or is she simply glad to be rid of the map?")\
    (set: $char's OldInrah's energy's 1st to it - 1)\
    (goto: "Old Inrah Buy Map Receive")\
